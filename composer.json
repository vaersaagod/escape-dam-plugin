{
    "name": "escape/escapedam",
    "description": "Escape DAM integration",
    "type": "craft-plugin",
    "version": "2.0.1",
    "keywords": [
        "craft",
        "cms",
        "craftcms",
        "craft-plugin",
        "escape dam"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Værsågod",
            "homepage": "https://vaersaagod.no"
        }
    ],
    "require": {
        "php": "^8.1.12",
        "craftcms/cms": "^4.3.7.1",
        "firebase/php-jwt": "^v6.3.2"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "platform": {
            "php": "8.1.12"
        },
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true
        }
    },
    "autoload": {
        "psr-4": {
          "escape\\escapedam\\": "src/"
        }
    },
    "extra": {
        "name": "Escape DAM",
        "handle": "escapedam",
        "changelogUrl": "",
        "class": "escape\\escapedam\\EscapeDam"
    },
    "require-dev": {
        "craftcms/rector": "dev-main"
    }
}
